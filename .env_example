# ===========================================
# Security Settings (REQUIRED)
# ===========================================
# SECRET_KEY: Used for JWT token encryption. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-min-32-chars

# ===========================================
# Cloud Database (REQUIRED)
# ===========================================
# Neon Postgres connection string.
# Copy the connection string directly from the Neon console
# (Connection Details → Connection string).
#
# Neon gives you a URL like:
#   postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#
# Paste it here exactly as-is — the code normalises the scheme and strips
# driver-incompatible parameters automatically.
#
NEON_API=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Qdrant Cloud vector database
# Get from: https://cloud.qdrant.io  (Cluster → API Keys)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API=your-qdrant-api-key

# ===========================================
# LLM API Keys
# ===========================================
GOOGLE_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=
TOGETHER_API_KEY=

# ===========================================
# External Service API Keys
# ===========================================
OPENWEATHER_API_KEY=
WEATHERSTACK_API_KEY=
GOV_DATA_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
BLAND_API_KEY=

# ===========================================
# Monitoring & Tracing
# ===========================================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=project-kisan

OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=project-kisan
