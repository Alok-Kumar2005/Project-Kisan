# ===========================================
# Security Settings (REQUIRED)
# ===========================================
# SECRET_KEY: Used for JWT token encryption. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-min-32-chars

# ===========================================
# LLM API Keys
# ===========================================
GOOGLE_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=
TOGETHER_API_KEY=

# ===========================================
# External Service API Keys
# ===========================================
OPENWEATHER_API_KEY=
WEATHERSTACK_API_KEY=
GOV_DATA_API_KEY=
ASSEMBLYAI_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
BLAND_API_KEY=

# ===========================================
# Monitoring & Tracing
# ===========================================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=project-kisan

OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=project-kisan

# ===========================================
# Database Configuration
# ===========================================
# Qdrant vector database URL (default: http://localhost:6333)
QDRANT_URL=http://localhost:6333

# SQLAlchemy database URL (default: sqlite:///./ai_companion.db)
DATABASE_URL=sqlite:///./ai_companion.db
DB_ECHO=false